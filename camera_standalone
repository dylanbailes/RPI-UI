import sys
import numpy as np

try:
    import PySpin
    PYSPIN_AVAILABLE = True
except ImportError:
    PYSPIN_AVAILABLE = False

import cv2

from PyQt5.QtWidgets import (
    QApplication, QWidget, QVBoxLayout, QHBoxLayout, QLabel,
    QPushButton, QComboBox, QGroupBox, QFormLayout, QSizePolicy,
    QFrame, QMessageBox
)
from PyQt5.QtCore import Qt, QThread, pyqtSignal, QTimer
from PyQt5.QtGui import QImage, QPixmap, QFont


# =============================================
# Camera acquisition thread
# =============================================
# Runs PySpin acquisition in a background thread so the UI
# never blocks waiting for a frame. Emits each frame as a
# numpy array (H x W, uint8 for mono) via the frame_ready signal.
# =============================================
class CameraThread(QThread):
    frame_ready   = pyqtSignal(np.ndarray)   # raw mono frame
    error         = pyqtSignal(str)
    camera_lost   = pyqtSignal()

    def __init__(self, cam_index=0):
        super().__init__()
        self.cam_index = cam_index
        self._running  = False
        self._system   = None
        self._cam      = None

        # Camera settings — adjustable before start()
        self.exposure_us  = 5000.0   # microseconds  (5ms default)
        self.gain_db      = 0.0      # dB
        self.fps_target   = 15.0     # frames per second

    # ------------------------------------------
    # run() — called by QThread.start()
    # ------------------------------------------
    def run(self):
        if not PYSPIN_AVAILABLE:
            self.error.emit("PySpin not installed. See setup instructions.")
            return

        try:
            # Initialise Spinnaker system singleton
            self._system = PySpin.System.GetInstance()
            cam_list = self._system.GetCameras()

            if cam_list.GetSize() == 0:
                self.error.emit("No FLIR cameras detected.")
                cam_list.Clear()
                self._system.ReleaseInstance()
                return

            # Select camera by index (supports multi-camera later)
            self._cam = cam_list.GetByIndex(self.cam_index)
            cam_list.Clear()

            self._cam.Init()
            self._configure_camera()

            # Begin acquisition
            self._cam.BeginAcquisition()
            self._running = True

            while self._running:
                try:
                    # GetNextImage blocks until a frame arrives or timeout
                    image = self._cam.GetNextImage(1000)  # 1s timeout

                    if image.IsIncomplete():
                        image.Release()
                        continue

                    # Convert to numpy — Firefly S is monochrome 16S2 = 16-bit
                    # Convert to Mono8 for display (can change to Mono16 for analysis)
                    converted = image.Convert(
                        PySpin.PixelFormat_Mono8,
                        PySpin.HQ_LINEAR
                    )
                    frame = converted.GetNDArray()   # shape: (H, W), dtype: uint8
                    image.Release()

                    self.frame_ready.emit(frame.copy())

                except PySpin.SpinnakerException as e:
                    if self._running:
                        self.error.emit(f"Acquisition error: {e}")
                    break

            self._cam.EndAcquisition()

        except PySpin.SpinnakerException as e:
            self.error.emit(f"Camera init error: {e}")
            self.camera_lost.emit()

        finally:
            self._cleanup()

    # ------------------------------------------
    # _configure_camera()
    # ------------------------------------------
    # Sets acquisition mode, exposure, gain, and frame rate
    # via the GenICam node map — same parameters SpinView exposes.
    # ------------------------------------------
    def _configure_camera(self):
        nodemap = self._cam.GetNodeMap()

        # Continuous acquisition mode
        node_acq = PySpin.CEnumerationPtr(nodemap.GetNode("AcquisitionMode"))
        if PySpin.IsAvailable(node_acq) and PySpin.IsWritable(node_acq):
            node_continuous = node_acq.GetEntryByName("Continuous")
            if PySpin.IsAvailable(node_continuous):
                node_acq.SetIntValue(node_continuous.GetValue())

        # Exposure — turn off auto, set manual value
        node_exp_auto = PySpin.CEnumerationPtr(nodemap.GetNode("ExposureAuto"))
        if PySpin.IsAvailable(node_exp_auto) and PySpin.IsWritable(node_exp_auto):
            node_off = node_exp_auto.GetEntryByName("Off")
            if PySpin.IsAvailable(node_off):
                node_exp_auto.SetIntValue(node_off.GetValue())

        node_exp = PySpin.CFloatPtr(nodemap.GetNode("ExposureTime"))
        if PySpin.IsAvailable(node_exp) and PySpin.IsWritable(node_exp):
            exp_clamped = max(node_exp.GetMin(),
                              min(self.exposure_us, node_exp.GetMax()))
            node_exp.SetValue(exp_clamped)

        # Gain — turn off auto, set manual value
        node_gain_auto = PySpin.CEnumerationPtr(nodemap.GetNode("GainAuto"))
        if PySpin.IsAvailable(node_gain_auto) and PySpin.IsWritable(node_gain_auto):
            node_off = node_gain_auto.GetEntryByName("Off")
            if PySpin.IsAvailable(node_off):
                node_gain_auto.SetIntValue(node_off.GetValue())

        node_gain = PySpin.CFloatPtr(nodemap.GetNode("Gain"))
        if PySpin.IsAvailable(node_gain) and PySpin.IsWritable(node_gain):
            gain_clamped = max(node_gain.GetMin(),
                               min(self.gain_db, node_gain.GetMax()))
            node_gain.SetValue(gain_clamped)

        # Frame rate — enable and set target
        node_fps_enable = PySpin.CBooleanPtr(
            nodemap.GetNode("AcquisitionFrameRateEnable"))
        if PySpin.IsAvailable(node_fps_enable) and PySpin.IsWritable(node_fps_enable):
            node_fps_enable.SetValue(True)

        node_fps = PySpin.CFloatPtr(nodemap.GetNode("AcquisitionFrameRate"))
        if PySpin.IsAvailable(node_fps) and PySpin.IsWritable(node_fps):
            fps_clamped = max(node_fps.GetMin(),
                              min(self.fps_target, node_fps.GetMax()))
            node_fps.SetValue(fps_clamped)

    # ------------------------------------------
    # update_settings()
    # ------------------------------------------
    # Can be called from UI thread while streaming.
    # Temporarily pauses acquisition to write new node values.
    # ------------------------------------------
    def update_settings(self, exposure_us=None, gain_db=None, fps=None):
        if exposure_us is not None:
            self.exposure_us = exposure_us
        if gain_db is not None:
            self.gain_db = gain_db
        if fps is not None:
            self.fps_target = fps

        if self._cam is None or not self._running:
            return

        try:
            self._cam.EndAcquisition()
            self._configure_camera()
            self._cam.BeginAcquisition()
        except PySpin.SpinnakerException as e:
            self.error.emit(f"Settings update error: {e}")

    def stop(self):
        self._running = False
        self.wait()

    def _cleanup(self):
        try:
            if self._cam:
                self._cam.DeInit()
                del self._cam
        except Exception:
            pass
        try:
            if self._system:
                self._system.ReleaseInstance()
        except Exception:
            pass


# =============================================
# Camera viewer widget
# =============================================
# Embeds into the MCCB UI as a tab, or runs standalone.
# Displays live frames with controls for exposure, gain, FPS,
# and a snapshot button that saves a timestamped PNG.
# =============================================
class CameraViewerWidget(QWidget):
    def __init__(self, cam_index=0, parent=None):
        super().__init__(parent)
        self.cam_index    = cam_index
        self.cam_thread   = None
        self._frame_count = 0
        self._last_frame  = None

        layout = QVBoxLayout()
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(0)

        # ---- Top control bar ----
        ctrl_bar = QFrame()
        ctrl_bar.setStyleSheet("background: #F2F2F2; border-bottom: 2px solid #000;")
        ctrl_layout = QHBoxLayout(ctrl_bar)
        ctrl_layout.setContentsMargins(12, 8, 12, 8)
        ctrl_layout.setSpacing(16)

        # Start / Stop button
        self.toggle_btn = QPushButton("START CAMERA")
        self.toggle_btn.setFixedHeight(40)
        self.toggle_btn.clicked.connect(self._toggle_stream)
        ctrl_layout.addWidget(self.toggle_btn)

        # Snapshot button
        snap_btn = QPushButton("SNAPSHOT")
        snap_btn.setFixedHeight(40)
        snap_btn.setProperty("variant", "secondary")
        snap_btn.clicked.connect(self._save_snapshot)
        ctrl_layout.addWidget(snap_btn)

        ctrl_layout.addStretch()

        # FPS counter label
        self.fps_label = QLabel("FPS: —")
        self.fps_label.setFont(QFont("Monospace", 11))
        ctrl_layout.addWidget(self.fps_label)

        layout.addWidget(ctrl_bar)

        # ---- Main area: video + settings side panel ----
        content = QHBoxLayout()
        content.setSpacing(0)

        # Video display label — fills all available space
        self.video_label = QLabel()
        self.video_label.setAlignment(Qt.AlignCenter)
        self.video_label.setStyleSheet("background: #000000;")
        self.video_label.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Expanding)
        self.video_label.setText("CAMERA OFFLINE")
        self.video_label.setFont(QFont("Monospace", 14))
        self.video_label.setStyleSheet(
            "background:#000; color:#00FF00; font-size:14px;")
        content.addWidget(self.video_label, stretch=4)

        # Settings panel
        settings_panel = self._build_settings_panel()
        settings_panel.setFixedWidth(220)
        content.addWidget(settings_panel, stretch=0)

        layout.addLayout(content)
        self.setLayout(layout)

        # FPS timer — counts frames emitted per second
        self._fps_timer = QTimer(self)
        self._fps_timer.timeout.connect(self._update_fps)
        self._fps_timer.start(1000)

    # ------------------------------------------
    def _build_settings_panel(self):
        panel = QFrame()
        panel.setStyleSheet("border-left: 2px solid #000; background: #FAFAFA;")
        v = QVBoxLayout(panel)
        v.setContentsMargins(16, 16, 16, 16)
        v.setSpacing(16)

        # Camera settings group
        cam_box = QGroupBox("CAMERA SETTINGS")
        form = QFormLayout()
        form.setSpacing(12)

        # Exposure
        self.exp_combo = QComboBox()
        exposures = ["500", "1000", "2000", "5000", "10000", "20000", "50000"]
        self.exp_combo.addItems([f"{e} µs" for e in exposures])
        self.exp_combo.setCurrentIndex(3)   # 5000µs default
        self.exp_combo.currentIndexChanged.connect(self._on_exposure_changed)
        form.addRow("Exposure:", self.exp_combo)

        # Gain
        self.gain_combo = QComboBox()
        gains = ["0", "3", "6", "10", "15", "20"]
        self.gain_combo.addItems([f"{g} dB" for g in gains])
        self.gain_combo.setCurrentIndex(0)
        self.gain_combo.currentIndexChanged.connect(self._on_gain_changed)
        form.addRow("Gain:", self.gain_combo)

        # Target FPS
        self.fps_combo = QComboBox()
        fps_options = ["5", "10", "15", "20", "30"]
        self.fps_combo.addItems([f"{f} fps" for f in fps_options])
        self.fps_combo.setCurrentIndex(2)   # 15fps default
        self.fps_combo.currentIndexChanged.connect(self._on_fps_changed)
        form.addRow("Target FPS:", self.fps_combo)

        cam_box.setLayout(form)
        v.addWidget(cam_box)

        # Camera info group
        info_box = QGroupBox("DEVICE INFO")
        info_layout = QVBoxLayout()
        self.info_label = QLabel("Not connected")
        self.info_label.setWordWrap(True)
        self.info_label.setFont(QFont("Monospace", 9))
        info_layout.addWidget(self.info_label)
        info_box.setLayout(info_layout)
        v.addWidget(info_box)

        v.addStretch()

        return panel

    # ------------------------------------------
    # _toggle_stream()
    # ------------------------------------------
    # Starts or stops the CameraThread.
    # ------------------------------------------
    def _toggle_stream(self):
        if self.cam_thread and self.cam_thread.isRunning():
            self._stop_stream()
        else:
            self._start_stream()

    def _start_stream(self):
        if not PYSPIN_AVAILABLE:
            QMessageBox.critical(self, "PySpin Missing",
                "PySpin is not installed.\n\n"
                "Install the Spinnaker SDK and PySpin wheel from:\n"
                "https://www.flir.com/products/spinnaker-sdk/")
            return

        # Read initial settings from combo boxes
        exp_us  = float(self.exp_combo.currentText().split()[0])
        gain_db = float(self.gain_combo.currentText().split()[0])
        fps     = float(self.fps_combo.currentText().split()[0])

        self.cam_thread = CameraThread(self.cam_index)
        self.cam_thread.exposure_us = exp_us
        self.cam_thread.gain_db     = gain_db
        self.cam_thread.fps_target  = fps

        self.cam_thread.frame_ready.connect(self._on_frame)
        self.cam_thread.error.connect(self._on_cam_error)
        self.cam_thread.camera_lost.connect(self._on_camera_lost)
        self.cam_thread.start()

        self.toggle_btn.setText("STOP CAMERA")
        self.video_label.setText("INITIALISING…")

        # Read and display device info after a short delay
        QTimer.singleShot(1500, self._read_device_info)

    def _stop_stream(self):
        if self.cam_thread:
            self.cam_thread.stop()
            self.cam_thread = None
        self.toggle_btn.setText("START CAMERA")
        self.video_label.setPixmap(QPixmap())
        self.video_label.setText("CAMERA OFFLINE")
        self.info_label.setText("Not connected")

    # ------------------------------------------
    # _on_frame()
    # ------------------------------------------
    # Receives a numpy (H, W) uint8 mono frame from CameraThread.
    # Converts to QImage → QPixmap → scales to fit the label
    # while preserving aspect ratio.
    # ------------------------------------------
    def _on_frame(self, frame: np.ndarray):
        self._frame_count += 1
        self._last_frame = frame

        h, w = frame.shape
        q_img = QImage(frame.data, w, h, w, QImage.Format_Grayscale8)
        pixmap = QPixmap.fromImage(q_img)

        # Scale to fit label, keeping aspect ratio, no upscaling artefacts
        scaled = pixmap.scaled(
            self.video_label.size(),
            Qt.KeepAspectRatio,
            Qt.SmoothTransformation
        )
        self.video_label.setPixmap(scaled)

    # ------------------------------------------
    # _update_fps()
    # ------------------------------------------
    # Called every 1s by the FPS timer.
    # Counts frames received since last tick.
    # ------------------------------------------
    def _update_fps(self):
        self.fps_label.setText(f"FPS: {self._frame_count}")
        self._frame_count = 0

    # ------------------------------------------
    # _save_snapshot()
    # ------------------------------------------
    # Saves the last received frame as a timestamped
    # 16-bit TIFF for maximum dynamic range preservation.
    # Falls back to PNG if no frame received yet.
    # ------------------------------------------
    def _save_snapshot(self):
        if self._last_frame is None:
            QMessageBox.information(self, "NO FRAME", "No frame received yet.")
            return

        import datetime, os
        timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        folder    = os.path.expanduser("~/mccb_snapshots")
        os.makedirs(folder, exist_ok=True)
        path = os.path.join(folder, f"snap_{timestamp}.png")

        cv2.imwrite(path, self._last_frame)
        QMessageBox.information(self, "SNAPSHOT SAVED", f"Saved to:\n{path}")

    # ------------------------------------------
    # Settings change handlers
    # ------------------------------------------
    def _on_exposure_changed(self):
        if self.cam_thread:
            exp = float(self.exp_combo.currentText().split()[0])
            self.cam_thread.update_settings(exposure_us=exp)

    def _on_gain_changed(self):
        if self.cam_thread:
            gain = float(self.gain_combo.currentText().split()[0])
            self.cam_thread.update_settings(gain_db=gain)

    def _on_fps_changed(self):
        if self.cam_thread:
            fps = float(self.fps_combo.currentText().split()[0])
            self.cam_thread.update_settings(fps=fps)

    def _read_device_info(self):
        """Pull model/serial from Spinnaker node map and display it."""
        if not self.cam_thread or not self.cam_thread._cam:
            return
        try:
            nodemap = self.cam_thread._cam.GetTLDeviceNodeMap()
            def node_str(name):
                n = PySpin.CStringPtr(nodemap.GetNode(name))
                return n.GetValue() if PySpin.IsAvailable(n) else "N/A"
            model  = node_str("DeviceModelName")
            serial = node_str("DeviceSerialNumber")
            self.info_label.setText(f"Model:\n{model}\n\nSerial:\n{serial}")
        except Exception:
            self.info_label.setText("Info unavailable")

    def _on_cam_error(self, msg):
        QMessageBox.warning(self, "CAMERA ERROR", msg)

    def _on_camera_lost(self):
        self._stop_stream()
        QMessageBox.critical(self, "CAMERA LOST",
                             "Camera connection was lost.")

    def closeEvent(self, e):
        self._stop_stream()
        e.accept()


# =============================================
# Standalone entry point
# (also shows how to add to MCCB_UI tabs)
# =============================================
if __name__ == "__main__":
    app = QApplication(sys.argv)
    viewer = CameraViewerWidget(cam_index=0)
    viewer.setWindowTitle("FLIR Firefly S — Camera Viewer")
    viewer.setGeometry(100, 100, 960, 600)
    viewer.show()
    sys.exit(app.exec_())